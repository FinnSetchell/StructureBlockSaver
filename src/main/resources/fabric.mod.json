{
	"schemaVersion": 1,
	"id": "structure-block-saver",
	"version": "${version}",
	"name": "Structure Block Saver",
	"description": "Saves all structure blocks in a selected area with a single command.",
	"authors": [
		"finndog"
	],
	"contact": {
	},
	"license": "MIT",
	"icon": "assets/structure-block-saver/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.finndog.StructureBlockSaver"
		],
		"client": [
			"com.finndog.StructureBlockSaverClient"
		]
	},
	"mixins": [
		"structure-block-saver.mixins.json",
		{
			"config": "structure-block-saver.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.10",
		"java": ">=21",
		"fabric-api": "*"
